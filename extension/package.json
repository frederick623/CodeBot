{
  "name": "code-assistant",
  "displayName": "Code Assistant",
  "version": "0.1.0",
  "engines": { "vscode": "^1.90.0" },
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": { "supported": "limited" }
  },
  "contributes": {
    "commands": [
      { "command": "codebot.ask", "title": "Code Assistant: Ask" }
    ],
    "configuration": {
      "title": "Code Assistant",
      "properties": {
        "codebot.daemonUrl": {
          "type": "string",
          "default": "http://127.0.0.1:9099"
        },
        "codebot.telemetry": { "type": "boolean", "default": false }
      }
    }
  },
  "scripts": { "compile": "tsc -p ./" },
  "devDependencies": { "@types/vscode": "^1.90.0", "typescript": "^5.5.0" }
}